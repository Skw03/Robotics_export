#!/usr/bin/env bash
set -euo pipefail

has_pickup=false
for arg in "$@"; do
  if [[ "$arg" == "-p" || "$arg" == "--pickups" ]]; then
    has_pickup=true
    break
  fi
done

if [[ "$has_pickup" == false ]]; then
  set -- "$@" \
    -p pantry \
    -ph file_dispenser \
    -pp file,1 \
    -d hardware_2 \
    -dh file_ingestor \
    -dp file,1
fi

exec ros2 run office_tasks dispatch_delivery "$@"
